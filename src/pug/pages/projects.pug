extends ../layout/main
block variable
  -
    var title_page = 'projects'
    var id_page = 'id-page-projects'
    var class_page = 'page-template-projects'
    var page_title = "проєкти"
    var img_bg = "../../assets/images/bg/top_bg_projects.jpg"
    
block meta
  title= title_page
  meta(name='description' content='')
block head
  link(rel='stylesheet' href="./assets/styles/main.min.css")
block scripts
  script(defer src='./assets/scripts/vendors.bundle.js')
  script(defer src='./assets/scripts/header.bundle.js')
  script(defer src='./assets/scripts/footer.bundle.js')
  script(defer src='./assets/scripts/index.bundle.js')
block content
  include ../includes/section_top_subpage.pug
    - var page_title = page_title
    - var img_bg = img_bg
  include ../includes/section_projects.pug
      
block footer
  include ../includes/footer.pug

block header
  include ../includes/header.pug