                                    span Житловий комплекс
                                    span Brother
                                .flat_card__img 
                                    img(src="../../assets/images/plannings/planing.svg" alt="planning")
                                .flat_card__center 
                                    .flat_card__center_left 
                                        span cтудія м²
                                        span 34.04
                                    .flat_card__center_center 
                                        span /
                                    .flat_card__center_right 
                                        span грн/м²
                                        span 53,894
                                .flat_card__bottom 
                                    span Секція: 6
                                    span Поверх: 27
                                    span Кімнат: 3
                                .flat_card__address 
